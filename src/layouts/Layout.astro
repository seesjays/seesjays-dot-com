---
import { SEO } from "astro-seo";
import Topbar from "../components/Topbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Simun", description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content="❤️ love ❤️" />
    <SEO title={title} description={description} />
  </head>
  <body>
    <div class="grid grid-flow-col auto-rows-min grid-cols-[200px_1fr_200px]">
      <div class="col-start-2 h-fit">
        <Topbar />
      </div>
      <div
        id="sunset-district"
        class="col-span-full border-y border-neutral-200 bg-orange-100 py-32"
      >
      </div>
      <main class="col-start-2">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
