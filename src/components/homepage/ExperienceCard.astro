---
export type Job = {
  title: string;
  timespan: string;
  description: string;
  primary: string;
  secondary: string;
};

export interface Props {
  job: Job;
}

const { job } = Astro.props;
const primary = job.primary;
const secondary = job.secondary;
const [titleLead, titleSuffix] = job.title.split("|");
---

<div
  class="flex flex-row items-center justify-between border border-b-2 border-neutral-200 border-b-(--primary) dark:border-b-(--primary) bg-(--primary)/3 dark:bg-(--primary)/10 pr-4 max-sm:flex-col max-sm:items-start max-sm:py-2 max-sm:pl-4 dark:border-neutral-700"
>
  <span class="pt-1 pl-3 font-normal max-sm:border-none max-sm:pl-0">
    <span class="font-medium">{titleLead.trim()} | </span>
    <span class="italic">{titleSuffix.trim()}</span>
  </span>
  <span
    class="pt-1 font-normal text-(--primary) max-sm:text-sm dark:text-(--secondary) brightness-80 dark:brightness-125"
  >
    {job.timespan}
  </span>
</div>
<p class="mt-3 mb-6 max-sm:mt-3">{job.description}</p>

<style define:vars={{ primary, secondary }}></style>
