---
import { Icon } from "astro-icon/components";
---

<button
  id="theme-toggle"
  type="button"
  class="ml-auto inline-grid place-items-center text-neutral-950 transition-colors hover:text-[#8B5339] dark:text-orange-100 dark:hover:text-orange-300"
  aria-label="Toggle between Dark and Light mode"
  data-theme-toggle
  transition:persist
>
  <Icon
    name="ic:round-dark-mode"
    class="size-6 text-current dark:hidden"
    aria-hidden="true"
  />
  <Icon
    name="ic:round-light-mode"
    class="hidden size-6 text-current dark:block"
    aria-hidden="true"
  />
</button>

<script>
  document.querySelector("#theme-toggle")!.addEventListener("click", () => {
    console.log("swapped color schema");
    document.documentElement.classList.toggle("dark");
    localStorage.setItem(
      "color-schema",
      document.documentElement.classList.contains("dark") ? "dark" : "light",
    );
  });
</script>
